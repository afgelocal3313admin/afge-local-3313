<script>
var myIndex = 0;
Adcarousel();

function Adcarousel() {
  var i;
  var x = document.getElementsByClassName("ADmySlides");
  for (i = 0; i < x.length; i++) {
    x[i].style.display = "none";  
  }
  myIndex++;
  if (myIndex > x.length) {myIndex = 1}    
  x[myIndex-1].style.display = "block";  
  setTimeout(Adcarousel, 4000); // Change image every 2 seconds
}
</script>
